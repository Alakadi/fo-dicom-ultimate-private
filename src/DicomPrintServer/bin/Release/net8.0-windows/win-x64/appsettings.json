{
  "PrintServer": {
    "CenterName": "مركز الأشعة الطبية",
    "CenterLogoPath": "C:\\Config\\logo.png",
    "DefaultOutputFolder": "C:\\PrintOutput",
    "Listeners": [
      {
        "Port": 8000,
        "AET": "PRINTER_A",
        "WindowsPrinterName": "Microsoft Print to PDF",
        "PrintToWindowsPrinter": true,
        "SaveJpg": true,
        "JpgQuality": 95,
        "SavePdf": false,
        "OutputFolder": "C:\\PrintOutput\\PortA",
        "FilmResolutionDpi": 150,
        "ImageProcessing": {
          "Gamma": 1.0,
          "Contrast": 1.0,
          "Brightness": 0.0,
          "Sharpness": 0.0,
          "Invert": false,
          "WindowWidth": 0,
          "WindowCenter": 128,
          "CalibrationMode": false,
          "CalibrationPattern": "TG18QC"
        },
        "Annotations": {
          "ShowHeader": false,
          "HeaderTemplate": "{Institution} | {PatientName} | {StudyDate}",
          "ShowFooter": false,
          "FooterTemplate": "{Modality} | {PrintDate} | {AET}",
          "ShowWatermark": false,
          "WatermarkText": "TRIAL — NOT FOR CLINICAL USE"
        }
      },
      {
        "Port": 8001,
        "AET": "PRINTER_B",
        "WindowsPrinterName": "HP LaserJet",
        "PrintToWindowsPrinter": false,
        "SaveJpg": true,
        "JpgQuality": 90,
        "SavePdf": false,
        "OutputFolder": "C:\\PrintOutput\\PortB",
        "FilmResolutionDpi": 150,
        "ImageProcessing": {
          "Gamma": 1.0,
          "Contrast": 1.1,
          "Brightness": 0.05,
          "Sharpness": 0.5,
          "Invert": false,
          "WindowWidth": 0,
          "WindowCenter": 128,
          "CalibrationMode": false,
          "CalibrationPattern": "GreyRamp"
        },
        "Annotations": {
          "ShowHeader": true,
          "HeaderTemplate": "{Institution} | {PatientName} | {StudyDate}",
          "ShowFooter": true,
          "FooterTemplate": "{Modality} | {PrintDate} | {AET}",
          "ShowWatermark": false,
          "WatermarkText": "TRIAL — NOT FOR CLINICAL USE"
        }
      }
    ],
    "AdminApi": {
      "Enabled": true,
      "Port": 9000,
      "AdminUsername": "admin",
      "AdminPasswordHash": ""
    },
    "WhatsApp": {
      "Enabled": false,
      "Provider": "CallMeBot",
      "ApiKey": "",
      "AccountSid": null,
      "AuthToken": null,
      "FromNumber": null,
      "PhoneNumberId": null,
      "MessageTemplate": "✅ طباعة مكتملة\nالمريض: {PatientName}\nالصفحات: {PageCount}\n{DateTime}",
      "SendImage": true,
      "DefaultRecipientPhone": null
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "DicomPrintServer": "Debug"
    }
  }
}
