{
  "metadata": [
    {
      "src": [
        {
          "files": [ "FO-DICOM.Core.csproj" ],
          "exclude": [ "**/bin/**", "**/obj/**", "External/**" ],
          "src": "../../FO-DICOM.Core"
        }
      ],
      "dest": "obj/api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "**/*.yml" ],
        "src": "obj/api",
        "dest": "api/"
      },
      {
        "files": [ "index.md", "toc.yml" ]
      },
      {
        "files": [ "*.md", "toc.yml" ],
        "src": "usage",
        "dest": "usage/"
      },
      {
        "files": [ "ChangeLog.md", "Contributors.md" ],
        "src": "../..",
        "dest": "developer/"
      },
      {
        "files": [ "*.md", "toc.yml" ],
        "src": "developer",
        "dest": "developer/"
      },
      {
        "files": [ "CONTRIBUTING.md" ],
        "src": "../../.github",
        "dest": "developer/"
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "template": [
      "default",
      "modern",
      "templates/material",
      "templates/fo-dicom"
    ],
    "globalMetadata": {
      "_appTitle": "Fellow Oak DICOM 5 API",
      "_appName": "Fellow Oak DICOM",
      "_appLogoPath": "images/logo.svg",
      "_appFaviconPath": "images/favicon.ico",
      "_appFooter": "Copyright (c) 2012-2026 fo-dicom contributors",
      "_enableSearch": "true",
      "_disableContribution": true
    },
    "postProcessors": [ "ExtractSearchIndex" ],
    "markdownEngineProperties": {
      "markdigExtensions": [
        "Abbreviations",
        "Footnotes",
        "Bootstrap",
        "Diagrams"
      ]
    },
    "markdownEngineName": "markdig",
    "dest": "_site",
    "xrefService": [ "https://xref.docs.microsoft.com/query?uid={uid}" ]
  }
}
